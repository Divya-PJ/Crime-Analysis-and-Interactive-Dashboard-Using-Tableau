      <column caption='Time Block' datatype='string' name='[Calculation_1582215794155523]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEPART(&apos;hour&apos;,[Date]) &gt;= 5 AND DATEPART(&apos;hour&apos;,[Date]) &lt; 12 THEN &quot;Morning&quot;&#13;&#10;&#13;&#10;ELSEIF DATEPART(&apos;hour&apos;,[Date]) &gt;= 12 AND DATEPART(&apos;hour&apos;,[Date]) &lt; 17 THEN &quot;Afternoon&quot;&#13;&#10;&#13;&#10;ELSEIF DATEPART(&apos;hour&apos;,[Date]) &gt;= 17 AND DATEPART(&apos;hour&apos;,[Date]) &lt; 21 THEN &quot;Evening&quot;&#13;&#10;&#13;&#10;ELSE &quot;Night&quot;&#13;&#10;&#13;&#10;END' />
      </column>
